APP_NAME=Laravel
# Safe-by-default: a copy of this file to production must NOT expose debug output.
# For local development, set APP_ENV=local and APP_DEBUG=true in your own .env.
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
# Production: use a dedicated least-privilege user with a strong password —
# never the MySQL root account, never an empty password.
DB_USERNAME=zaga
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Set to true in production (served over HTTPS) so the session cookie is
# never sent over plain HTTP.
SESSION_SECURE_COOKIE=false

# Comma-separated origins allowed to call the /api/* device endpoints from a
# browser. Native offline clients are unaffected. Restrict this in production.
CORS_ALLOWED_ORIGINS=*

# Comma-separated allowlist of SMTP hosts an admin may set from the settings UI.
# Leave blank to allow any host (dev); set it in production.
MAIL_ALLOWED_HOSTS=

# Minutes until a device API token expires. Leave blank to keep tokens
# non-expiring (see the device-client coordination note before enabling).
SANCTUM_EXPIRATION=

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
